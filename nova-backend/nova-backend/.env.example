NODE_ENV=development
PORT=5000

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/nova

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7

# Comma-separated list of frontend origins allowed to call this API with credentials
CLIENT_URL=http://localhost:3000,https://nova.orbitstack.in

# Used only by the seed script to create the first admin account
SEED_ADMIN_EMAIL=admin@nova.orbitstack.in
SEED_ADMIN_PASSWORD=ChangeMe123!
